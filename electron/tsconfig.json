{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "electron"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "../electron-dist",
    "sourceMap": true
  },
  "include": ["*.ts"],
  "exclude": ["*.test.ts"]
}
